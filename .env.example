# Optional API keys — the pipeline runs end-to-end without them via deterministic
# synthetic fallbacks, but live data quality goes up significantly when set.

# --- Kalshi (RSA-signed v2 trade API) ---
# Generate via: Kalshi → Settings → API Keys → "Create new key". Save the
# downloaded private key locally and point KALSHI_PRIVATE_KEY_PATH at it.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=secrets/kalshi_private_key.pem
KALSHI_API_BASE=https://api.elections.kalshi.com
KALSHI_WC_EVENT=KXMENWORLDCUP-26

# --- Polymarket ---
# The public Gamma endpoint serves the World Cup winner market unauthenticated,
# so leave the API key blank unless you intend to place orders via the CLOB.
POLYMARKET_API_KEY=
POLYMARKET_ADDRESS=
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_WC_SLUG=2026-fifa-world-cup-winner-595

# --- Pipeline tuning knobs (override pipeline/config.py defaults) ---
SOCCERDATA_CACHE_DIR=./data/cache
MODEL_RANDOM_SEED=42
N_SIMULATIONS=10000
K_FACTOR=24
DECAY_HALFLIFE_DAYS=365
